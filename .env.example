# === AI PROVIDERS (5-Provider PRISM Architecture) ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRISM v0.1: OpenRouter (1M context — ATS Simulator + CV Enhancer)
# Free: 200 req/day, 20 RPM | Model: gemini-2.0-flash-exp:free
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRISM v0.1: Mistral AI (Universal Fallback)
# Free: 1B tokens/month | Get key at: https://console.mistral.ai/
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRISM v0.1: Groq Compound Beta (Agentic — uses same GROQ_API_KEY)
# Model: compound-beta (built-in web_search + visit_url tools)
# No separate key needed — uses GROQ_API_KEY above

# === TELEGRAM ===
TG_BOT_TOKEN=7xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_CHAT_ID=xxxxxxxxxx
TG_API_ID=xxxxxxxx
TG_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === SEARCH & DISCOVERY ===
# SerpAPI: 230+ searches/month plan (get key at https://serpapi.com/)
# Budget: 8/day weekdays, 5/day weekends — split across A-01, A-09, on-demand
SERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Bing Search API (optional, 1000 free/month): https://portal.azure.com/
BING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === PROXY & STEALTH ===
WEBSHARE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_WORKER_URL=https://your-relay.your-subdomain.workers.dev
CF_RELAY_SECRET=your-secret-key-here

# === v6.0 SCRAPING API FALLBACKS (ALL FREE, NO CREDIT CARD) ===
# ScraperAPI: 1,000 free credits/month — Signup: https://www.scraperapi.com/signup
SCRAPERAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Scrape.do: 1,000 free credits/month — Signup: https://scrape.do/signup
SCRAPEDO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ScrapingBee: 1,000 one-time credits — Signup: https://www.scrapingbee.com/signup
SCRAPINGBEE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === v6.0 SCHEDULE MODE ===
# 'weekly' = Smart twice-per-week-per-portal (recommended, reduces ban risk 70%)
# 'daily' = Legacy daily scraping (v5.1 behavior)
SCHEDULE_MODE=weekly

# === TWITTER/X ===
X_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === SECURITY (Admin Access Control) ===
# The sole admin Telegram ID — this user controls all access
ADMIN_TELEGRAM_ID=1284690336
# Admin username (without @)
ADMIN_USERNAME=abuzarkhan999

# === MINI APP ===
# URL where the InternHub Pro mini app is hosted
# If NOT set, auto-derives from RENDER_EXTERNAL_URL (served at /app/ path)
# The mini-app is built into mini-app/dist/ and served by the same aiohttp server.
# Only set this explicitly if you host the mini-app separately (e.g., Cloudflare Pages)
# MINI_APP_URL=https://your-miniapp-url.pages.dev
# Leave commented to auto-derive: RENDER_EXTERNAL_URL + /app/

# === APP CONFIG ===
DATABASE_PATH=data/firstmover.db
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata
RENDER_DEPLOY=true

# === PRISM v0.1: EMAIL OUTREACH (Brevo / Sendinblue) ===
# Free: 300 emails/day | Get key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=your.email@gmail.com

# === PRISM v0.1: EMAIL VERIFICATION (Hunter.io) ===
# Free: 25 searches/month | Get key at: https://hunter.io/api-keys
HUNTER_IO_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === PRISM v0.1: EMBEDDING ENGINE ===
# sentence-transformers runs LOCALLY — no API key needed
# Model: all-MiniLM-L6-v2 (384-dim, ~80MB)
# Set to 'true' on Render (lazy-load saves 30s startup time)
LAZY_LOAD_EMBEDDINGS=true

# === SUPABASE (Persistent Cloud Database) ===
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# === RENDER WEB SERVICE ===
# PORT is set automatically by Render (usually 10000)
# RENDER_EXTERNAL_URL is set automatically by Render
# Example: https://operation-firstmover.onrender.com
# PORT=10000
# RENDER_EXTERNAL_URL=https://your-service.onrender.com
