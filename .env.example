# === MINI APP ===
# URL where the InternHub Pro mini app is hosted
# If NOT set, auto-derives from RENDER_EXTERNAL_URL (served at /app/ path)
# The mini-app is built into mini-app/dist/ and served by the same aiohttp server.
# Only set this explicitly if you host the mini-app separately (e.g., Cloudflare Pages)
# MINI_APP_URL=https://your-miniapp-url.pages.dev
# Leave commented to auto-derive: RENDER_EXTERNAL_URL + /app/

# === APP CONFIG ===
